// AgentNet Platform Schema
// Normalized action layer between AI agents and businesses
// PostgreSQL + Prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────────

enum UserRole {
  person
  business
  admin
}

enum ProfileStatus {
  available
  looking_for_work
  hiring
  busy
  inactive
}

enum CapabilityType {
  ordering
  booking
  messaging
  service_requests
  availability
  quotes
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
  no_show
}

enum ServiceRequestStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
}

enum QuoteStatus {
  pending
  sent
  accepted
  declined
  expired
}

enum IntegrationType {
  custom
  square
  calendly
  shopify
  toast
  stripe_checkout
  manual
}

enum PaymentMode {
  checkout_url
  business_api_charge
  pay_on_pickup
  invoice_later
  unsupported
}

// ─── USERS ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(person)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile          Profile?
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
  apiKeys          ApiKey[]
  messageSettings  MessageSettings?
  chatSessions     ChatSession[]

  @@map("users")
}

// ─── PROFILES ──────────────────────────────────────────

model Profile {
  id          String        @id @default(uuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        UserRole
  displayName String
  bio         String?
  location    String        @default("Tuscaloosa, AL")
  avatarUrl   String?
  status      ProfileStatus @default(available)
  isPublic    Boolean       @default(true)
  // Business-specific
  category        String?
  phone           String?
  website         String?
  address         String?
  hours           String?
  integrationType IntegrationType @default(manual)
  paymentMode     PaymentMode     @default(unsupported)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills          Skill[]
  services        Service[]
  capabilities    Capability[]
  businessEndpoints BusinessEndpoint[]
  infoSections    InfoSection[]
  orders          Order[]
  bookings        Booking[]
  serviceRequests ServiceRequest[] @relation("BusinessRequests")
  quotes          Quote[]
  actionLogs      ActionLog[]

  @@index([status])
  @@index([type])
  @@index([location])
  @@index([category])
  @@map("profiles")
}

// ─── SKILLS (for people) ───────────────────────────────

model Skill {
  id        String  @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  category  String?

  @@index([name])
  @@index([profileId])
  @@map("skills")
}

// ─── SERVICES ──────────────────────────────────────────

model Service {
  id          String  @id @default(uuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String?
  price       String?
  duration    Int?    // minutes, for bookable services
  isBookable  Boolean @default(false)

  @@index([category])
  @@index([profileId])
  @@map("services")
}

// ─── CAPABILITIES ──────────────────────────────────────
// Declares what actions a business supports

model Capability {
  id        String         @id @default(uuid())
  profileId String
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      CapabilityType
  isActive  Boolean        @default(true)

  @@unique([profileId, type])
  @@map("capabilities")
}

// ─── BUSINESS ENDPOINTS ────────────────────────────────
// Optional external API endpoints businesses register

model BusinessEndpoint {
  id        String @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  action    String  // "book", "availability", "order", "quote"
  url       String  // External endpoint URL
  method    String  @default("POST") // HTTP method
  headers   Json?   // Optional auth headers
  isActive  Boolean @default(true)

  @@unique([profileId, action])
  @@map("business_endpoints")
}

// ─── INFO SECTIONS ─────────────────────────────────────
// Structured data businesses expose: menu, services, hours, etc.
// Hierarchical: /info/:businessId/:section/:subsection

model InfoSection {
  id         String @id @default(uuid())
  profileId  String
  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  section    String  // "menu", "services", "hours", "location", "faq", "policies"
  subsection String? // Optional sub-path
  title      String?
  data       Json    // The structured data payload
  cachedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([profileId, section, subsection])
  @@index([profileId])
  @@map("info_sections")
}

// ─── ORDERS ────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  profileId   String      // business being ordered from
  profile     Profile     @relation(fields: [profileId], references: [id])
  customerId  String?     // optional user placing order
  items       Json        // [{id, name, qty, price}]
  total       Float?
  pickupTime  String?
  status      OrderStatus @default(pending)
  paymentMode String?     // checkout_url, pay_on_pickup, etc.
  checkoutUrl String?     // external checkout URL if applicable
  nextStep    String?     // what the agent/user should do next
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([profileId])
  @@index([status])
  @@map("orders")
}

// ─── BOOKINGS ──────────────────────────────────────────

model Booking {
  id          String        @id @default(uuid())
  profileId   String        // business being booked
  profile     Profile       @relation(fields: [profileId], references: [id])
  customerId  String?
  service     String        // service name or id
  dateTime    DateTime
  duration    Int?          // minutes
  status      BookingStatus @default(pending)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([profileId])
  @@index([dateTime])
  @@map("bookings")
}

// ─── SERVICE REQUESTS ──────────────────────────────────

model ServiceRequest {
  id             String               @id @default(uuid())
  profileId      String               // provider
  profile        Profile              @relation("BusinessRequests", fields: [profileId], references: [id])
  requesterId    String?
  service        String
  details        Json?                // Freeform details
  timePreference String?
  status         ServiceRequestStatus @default(pending)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([profileId])
  @@map("service_requests")
}

// ─── QUOTES ────────────────────────────────────────────

model Quote {
  id             String      @id @default(uuid())
  profileId      String      // business providing quote
  profile        Profile     @relation(fields: [profileId], references: [id])
  requesterId    String?
  service        String
  details        Json?
  estimatedPrice Float?
  currency       String      @default("USD")
  notes          String?
  status         QuoteStatus @default(pending)
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([profileId])
  @@map("quotes")
}

// ─── MESSAGES ──────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  subject     String
  body        String
  isRead      Boolean  @default(false)
  isDraft     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([senderId])
  @@map("messages")
}

// ─── API KEYS ──────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]
  rateLimit  Int       @default(60)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

// ─── MESSAGE SETTINGS ──────────────────────────────────

model MessageSettings {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowMessages   Boolean @default(true)
  allowAgentDraft Boolean @default(true)
  requireApproval Boolean @default(false)

  @@map("message_settings")
}

// ─── CHAT SESSIONS ─────────────────────────────────────
// Stores GPT-powered chat conversations

model ChatSession {
  id        String        @id @default(uuid())
  userId    String?       // Null for anonymous
  user      User?         @relation(fields: [userId], references: [id])
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user", "assistant", "tool"
  content   String
  toolCalls Json?       // Stored tool call data for replay
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

// ─── ACTION LOG ────────────────────────────────────────
// Audit trail for all platform actions

model ActionLog {
  id         String   @id @default(uuid())
  profileId  String?
  profile    Profile? @relation(fields: [profileId], references: [id])
  action     String   // "order", "book", "quote", "search", etc.
  method     String   // "GET", "POST"
  path       String   // The endpoint path
  payload    Json?
  response   Json?
  statusCode Int?
  source     String?  // "agent", "user", "system"
  apiKeyId   String?
  duration   Int?     // ms
  createdAt  DateTime @default(now())

  @@index([profileId])
  @@index([action])
  @@index([createdAt])
  @@map("action_logs")
}
