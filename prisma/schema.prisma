// AgentNet Platform Schema
// Normalized action layer between AI agents, campus entities, and businesses
// Bama-first campus MVP — University of Alabama
// PostgreSQL + Prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────────

enum UserRole {
  person
  business
  admin
}

// Entity types for profiles (what the profile represents)
enum EntityType {
  person       // professors, students, tutors, advisors
  business     // local businesses (barbershops, restaurants, etc.)
  site         // dining halls, libraries, rec centers, buildings
  opportunity  // research positions, internships, scholarships, jobs
}

enum CampusRole {
  student
  professor
  advisor
  tutor
  staff
  alumni
  researcher
}

enum OpportunityType {
  research
  internship
  scholarship
  job
  volunteer
  club
}

enum ProfileStatus {
  available
  looking_for_work
  hiring
  busy
  inactive
}

enum CapabilityType {
  ordering
  booking
  messaging
  service_requests
  availability
  quotes
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
  no_show
}

enum ServiceRequestStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
}

enum QuoteStatus {
  pending
  sent
  accepted
  declined
  expired
}

enum IntegrationType {
  custom
  square
  calendly
  shopify
  toast
  stripe_checkout
  manual
}

enum PaymentMode {
  checkout_url
  business_api_charge
  pay_on_pickup
  invoice_later
  unsupported
}

// ─── USERS ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(person)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles           Profile[]
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")
  apiKeys            ApiKey[]
  messageSettings    MessageSettings?
  chatSessions       ChatSession[]
  memories           UserMemory[]
  connectedAccounts  ConnectedAccount[]
  claimRequests      ClaimRequest[]

  @@map("users")
}

// ─── PROFILES ──────────────────────────────────────────
// Universal entity: person, business, site, or opportunity

model Profile {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        EntityType
  displayName String
  bio         String?
  location    String        @default("Tuscaloosa, AL")
  avatarUrl   String?
  status      ProfileStatus @default(available)
  isPublic    Boolean       @default(true)

  // ─── Shared fields
  category        String?
  phone           String?
  website         String?
  address         String?
  hours           String?
  tags            String[]    @default([])

  // ─── Business-specific
  integrationType IntegrationType @default(manual)
  paymentMode     PaymentMode     @default(unsupported)

  // ─── Campus-specific (person entities)
  campusRole      CampusRole?
  department      String?
  title           String?         // "Associate Professor", "Academic Advisor"
  officeLocation  String?         // "Shelby Hall 3218"
  officeHours     String?         // "Mon/Wed 2-4pm"

  // ─── Opportunity-specific
  opportunityType OpportunityType?
  deadline        DateTime?
  eligibility     String?         // "Juniors and Seniors in CS"
  applyUrl        String?
  compensation    String?         // "$15/hr", "Stipend: $2,000/semester"

  // ─── Claim flow
  isClaimable     Boolean   @default(false)
  claimedAt       DateTime?

  // ─── Webhook settings
  webhookUrl           String?
  webhookSecret        String?
  webhookEnabled       Boolean  @default(false)
  enabledWebhookEvents String[] @default([])
  webhookSchema        Json?    // Per-event custom field definitions for webhook payloads

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills          Skill[]
  services        Service[]
  capabilities    Capability[]
  businessEndpoints BusinessEndpoint[]
  infoSections    InfoSection[]
  orders          Order[]
  bookings        Booking[]
  serviceRequests ServiceRequest[] @relation("BusinessRequests")
  quotes          Quote[]
  actionLogs      ActionLog[]
  claimRequests   ClaimRequest[]
  webhookLogs     WebhookLog[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([location])
  @@index([category])
  @@index([department])
  @@index([campusRole])
  @@index([opportunityType])
  @@map("profiles")
}

// ─── SKILLS (for people) ───────────────────────────────

model Skill {
  id        String  @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  category  String?

  @@index([name])
  @@index([profileId])
  @@map("skills")
}

// ─── SERVICES ──────────────────────────────────────────

model Service {
  id          String  @id @default(uuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String?
  price       String?
  duration    Int?    // minutes, for bookable services
  isBookable  Boolean @default(false)

  @@index([category])
  @@index([profileId])
  @@map("services")
}

// ─── CAPABILITIES ──────────────────────────────────────
// Declares what actions a business supports

model Capability {
  id        String         @id @default(uuid())
  profileId String
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      CapabilityType
  isActive  Boolean        @default(true)

  @@unique([profileId, type])
  @@map("capabilities")
}

// ─── BUSINESS ENDPOINTS ────────────────────────────────
// Optional external API endpoints businesses register

model BusinessEndpoint {
  id        String @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  action    String  // "book", "availability", "order", "quote"
  url       String  // External endpoint URL
  method    String  @default("POST") // HTTP method
  headers   Json?   // Optional auth headers
  isActive  Boolean @default(true)

  @@unique([profileId, action])
  @@map("business_endpoints")
}

// ─── INFO SECTIONS ─────────────────────────────────────
// Structured data businesses expose: menu, services, hours, etc.
// Hierarchical: /info/:businessId/:section/:subsection

model InfoSection {
  id         String @id @default(uuid())
  profileId  String
  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  section    String  // "menu", "services", "hours", "location", "faq", "policies"
  subsection String? // Optional sub-path
  title      String?
  data       Json    // The structured data payload
  cachedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([profileId, section, subsection])
  @@index([profileId])
  @@map("info_sections")
}

// ─── ORDERS ────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  profileId   String      // business being ordered from
  profile     Profile     @relation(fields: [profileId], references: [id])
  customerId  String?     // optional user placing order
  items       Json        // [{id, name, qty, price}]
  total       Float?
  pickupTime  String?
  status      OrderStatus @default(pending)
  paymentMode String?     // checkout_url, pay_on_pickup, etc.
  checkoutUrl String?     // external checkout URL if applicable
  nextStep    String?     // what the agent/user should do next
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([profileId])
  @@index([status])
  @@map("orders")
}

// ─── BOOKINGS ──────────────────────────────────────────

model Booking {
  id          String        @id @default(uuid())
  profileId   String        // business being booked
  profile     Profile       @relation(fields: [profileId], references: [id])
  customerId  String?
  service     String        // service name or id
  dateTime    DateTime
  duration    Int?          // minutes
  status      BookingStatus @default(pending)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([profileId])
  @@index([dateTime])
  @@map("bookings")
}

// ─── SERVICE REQUESTS ──────────────────────────────────

model ServiceRequest {
  id             String               @id @default(uuid())
  profileId      String               // provider
  profile        Profile              @relation("BusinessRequests", fields: [profileId], references: [id])
  requesterId    String?
  service        String
  details        Json?                // Freeform details
  timePreference String?
  status         ServiceRequestStatus @default(pending)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([profileId])
  @@map("service_requests")
}

// ─── QUOTES ────────────────────────────────────────────

model Quote {
  id             String      @id @default(uuid())
  profileId      String      // business providing quote
  profile        Profile     @relation(fields: [profileId], references: [id])
  requesterId    String?
  service        String
  details        Json?
  estimatedPrice Float?
  currency       String      @default("USD")
  notes          String?
  status         QuoteStatus @default(pending)
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([profileId])
  @@map("quotes")
}

// ─── MESSAGES ──────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  subject     String
  body        String
  isRead      Boolean  @default(false)
  isDraft     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([senderId])
  @@map("messages")
}

// ─── API KEYS ──────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]
  rateLimit  Int       @default(60)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

// ─── MESSAGE SETTINGS ──────────────────────────────────

model MessageSettings {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowMessages   Boolean @default(true)
  allowAgentDraft Boolean @default(true)
  requireApproval Boolean @default(false)

  @@map("message_settings")
}

// ─── CHAT SESSIONS ─────────────────────────────────────
// Stores GPT-powered chat conversations

model ChatSession {
  id        String        @id @default(uuid())
  userId    String?       // Null for anonymous
  user      User?         @relation(fields: [userId], references: [id])
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user", "assistant", "tool"
  content   String
  toolCalls Json?       // Stored tool call data for replay
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

// ─── ACTION LOG ────────────────────────────────────────
// Audit trail for all platform actions

model ActionLog {
  id         String   @id @default(uuid())
  profileId  String?
  profile    Profile? @relation(fields: [profileId], references: [id])
  action     String   // "order", "book", "quote", "search", etc.
  method     String   // "GET", "POST"
  path       String   // The endpoint path
  payload    Json?
  response   Json?
  statusCode Int?
  source     String?  // "agent", "user", "system"
  apiKeyId   String?
  duration   Int?     // ms
  createdAt  DateTime @default(now())

  @@index([profileId])
  @@index([action])
  @@index([createdAt])
  @@map("action_logs")
}

// ─── USER MEMORY ───────────────────────────────────────
// Stores user preferences & context for personalization

model UserMemory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String   // "major", "year", "interests", "preferred_dining", "schedule"
  value     String   // JSON string or plain text
  source    String   @default("user_stated") // "user_stated", "inferred", "system"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("user_memories")
}

// ─── CONNECTED ACCOUNTS ────────────────────────────────
// Scaffolding for Outlook/Gmail/Canvas integration

model ConnectedAccount {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    // "outlook", "gmail", "canvas", "myBama"
  accessToken  String?
  refreshToken String?
  externalId   String?   // External account identifier
  scope        String?   // OAuth scopes granted
  isActive     Boolean   @default(false)
  connectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("connected_accounts")
}

// ─── CLAIM REQUESTS ────────────────────────────────────
// Allows users to claim unclaimed profiles (e.g., professor claims their pre-seeded profile)

model ClaimRequest {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("pending") // "pending", "approved", "rejected"
  evidence  String?  // e.g., ".edu email match", "admin approved"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, userId])
  @@index([profileId])
  @@index([userId])
  @@map("claim_requests")
}

// ─── WEBHOOK LOGS ──────────────────────────────────────
// Tracks webhook deliveries for debugging and retry

model WebhookLog {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  event       String   // "booking", "order", "quote", "service_request", "message"
  payload     Json     // Full payload sent
  url         String   // Webhook URL at time of delivery
  statusCode  Int?     // HTTP response code (null if network error)
  response    String?  // Response body (truncated)
  success     Boolean  @default(false)
  attempts    Int      @default(1)
  error       String?  // Error message if failed
  deliveredAt DateTime @default(now())

  @@index([profileId])
  @@index([event])
  @@index([deliveredAt])
  @@map("webhook_logs")
}